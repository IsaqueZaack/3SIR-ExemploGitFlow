  <folder name="Motivation" id="id-97ae628b95e04d4e8f8120822723d4a0" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Presidente da software house Super Solucoes" id="id-bb7576c6e4be4cecbb49fd28dd50a4cc"/>
    <element xsi:type="archimate:Driver" name="Formalizar todo atendimento de suporte" id="id-6b4a4b4ffc6f48d6be22849242e7592c"/>
    <element xsi:type="archimate:Driver" name="Conhecer o desempenho da equipe de suporte" id="id-7eb611c33af7406690ef4de0b4c80a78"/>
    <element xsi:type="archimate:Driver" name="Conhecer o nível de satisfação dos clientes" id="id-e21d9363c4004d4590e012f017747adc"/>
    <element xsi:type="archimate:Principle" name="Entre os indicadores de desempenho é obrigatória a medição do tempo de ciclo de atendimento do registro à solução do chamado" id="id-20c94a89b4364f7ba1458823c5c76274"/>
    <element xsi:type="archimate:Principle" name="Coletar feedback de todos os clientes que abriram chamados técnicos" id="id-e48c29a7a78f4c69b47ff57820b1ee82"/>
    <element xsi:type="archimate:Principle" name="Registrar dados sobre cada demanda feita no suporte permitindo a recuperação da informação e acompanhamento do atendimento" id="id-c2319fcd81a94e79a8d07cf99b00d0d5"/>
  </folder>
